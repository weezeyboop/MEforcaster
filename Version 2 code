.no-pubs-box{text-align:center;padding:20px;color:#2d4060;font-family:'IBM Plex Mono',monospace;font-size:11px;line-height:1.8}

/* ── ALERTS PANEL ── */
#alert-btn{margin-left:8px;padding:3px 10px;background:#1a1030;border:1px solid #5b3fd4;border-radius:20px;color:#a78bfa;font-size:10px;font-family:'IBM Plex Mono',monospace;cursor:pointer;transition:all .2s;position:relative}
#alert-btn:hover{background:#221440;color:#c4b5fd}
#alert-btn.has-new::after{content:'';position:absolute;top:-3px;right:-3px;width:8px;height:8px;background:#ef4444;border-radius:50%;border:2px solid #0b0f1a}
#alerts-panel{display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:100;background:#0b0f1a;flex-direction:column;overflow:hidden}
#alerts-panel.open{display:flex}
#alerts-header{background:#0f1422;border-bottom:1px solid #1e2a40;padding:12px 16px;display:flex;align-items:center;gap:12px;flex-shrink:0}
#alerts-header .ah-title{font-size:14px;font-weight:700;color:#e8edf5}
#alerts-header .ah-sub{font-size:10px;font-family:'IBM Plex Mono',monospace;color:#3a5070}
#alerts-close{margin-left:auto;padding:5px 12px;background:transparent;border:1px solid #1e2a40;border-radius:5px;color:#4a6080;font-size:11px;font-family:'Syne',sans-serif;cursor:pointer}
#alerts-close:hover{color:#8aa4c8;border-color:#2e4060}
#alerts-controls{background:#0d1220;border-bottom:1px solid #1e2a40;padding:10px 16px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;flex-shrink:0}
.ctrl-lbl{font-size:9px;font-family:'IBM Plex Mono',monospace;color:#3a5070;letter-spacing:.1em}
.ctrl-select{background:#131c2e;border:1px solid #1e2a40;border-radius:4px;color:#94a3b8;font-size:11px;font-family:'IBM Plex Mono',monospace;padding:4px 8px;cursor:pointer;outline:none}
.ctrl-select:focus{border-color:#2e4060}
#scan-btn{padding:7px 16px;background:#1a1030;border:1px solid #5b3fd4;border-radius:5px;color:#a78bfa;font-size:11px;font-weight:700;font-family:'Syne',sans-serif;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:7px}
#scan-btn:hover:not(:disabled){background:#221440;color:#c4b5fd}
#scan-btn:disabled{opacity:.5;cursor:wait}
#alerts-body{flex:1;overflow-y:auto;padding:16px}
#scan-progress{display:none;margin-bottom:16px}
.prog-bar-wrap{height:4px;background:#131c2e;border-radius:2px;overflow:hidden;margin-bottom:8px}
.prog-bar-fill{height:100%;background:linear-gradient(90deg,#5b3fd4,#a78bfa);border-radius:2px;transition:width .3s ease}
.prog-txt{font-size:10px;font-family:'IBM Plex Mono',monospace;color:#3a5070}
#alerts-summary{display:none;background:#0f1422;border:1px solid #1e2a40;border-radius:6px;padding:12px;margin-bottom:14px;display:flex;gap:16px;flex-wrap:wrap}
.sum-stat{text-align:center}
.sum-val{font-family:'IBM Plex Mono',monospace;font-size:20px;font-weight:500;color:#e8edf5}
.sum-lbl{font-size:8px;font-family:'IBM Plex Mono',monospace;color:#3a5070;letter-spacing:.1em;margin-top:2px}
#alerts-list{}
