function lookupIF(journal){
  if(!journal)return null;
  const j=journal.trim();
  if(JIF[j]!==undefined)return JIF[j];
  // Try partial match
  for(const k of Object.keys(JIF)){
    if(j.toLowerCase().includes(k.toLowerCase())||k.toLowerCase().includes(j.toLowerCase())){
      return JIF[k];
    }
  }
  return null;
}

// ─── DATE HELPERS ────────────────────────────────────────────────────────────
function getMinDate(daysBack){
  const d=new Date();
  d.setDate(d.getDate()-daysBack);
  return d.toISOString().split('T')[0].replace(/-/g,'/');
}

// ─── PUBMED HELPERS ───────────────────────────────────────────────────────────
function fetchWithTimeout(url, ms){
  const controller = new AbortController();
  const timer = setTimeout(()=>controller.abort(), ms);
  return fetch(url, {signal: controller.signal}).finally(()=>clearTimeout(timer));
}

async function pmSearch(query,minDate){
  const today=new Date().toISOString().split('T')[0].replace(/-/g,'/');
  const url=`https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi?db=pubmed&retmode=json&retmax=10&sort=pub+date&term=${encodeURIComponent(query)}&datetype=pdat&mindate=${minDate}&maxdate=${today}`;
  const r=await fetchWithTimeout(url, 8000);
  const d=await r.json();
  return d.esearchresult?.idlist||[];
}

async function pmSummary(ids){
  if(!ids.length)return[];
  const url=`https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esummary.fcgi?db=pubmed&retmode=json&id=${ids.join(',')}`;
  const r=await fetchWithTimeout(url, 10000);
  const d=await r.json();
  const result=d.result||{};
  return ids.map(id=>{
    const p=result[id];
    if(!p)return null;
    const authors=(p.authors||[]).slice(0,3).map(a=>a.name).join(', ')+(p.authors?.length>3?' et al.':'');
    const pubdate=p.pubdate||p.epubdate||'';
    const year=pubdate.match(/\d{4}/)?.[0]||'';
    const month=pubdate.split(' ')[1]||'';
    return{
      pmid:id,
      title:p.title||'',
      journal:p.source||'',
      authors,year,month,
      doi:p.articleids?.find(a=>a.idtype==='doi')?.value||null,
    };
  }).filter(Boolean);
}

function buildQuery(name,species){
  const spTerms=[...new Set(species.map(s=>(SP[s]||{label:s}).label))];
  return `"${name}"[tiab] AND (${spTerms.map(s=>`"${s}"[tiab]`).join(' OR ')})`;
}

// ─── SCAN ENGINE ─────────────────────────────────────────────────────────────
let scanning=false;

function openAlerts(){
  document.getElementById('alerts-panel').classList.add('open');
}
function closeAlerts(){
  document.getElementById('alerts-panel').classList.remove('open');
}

async function startScan(){
  if(scanning)return;
  scanning=true;
  const btn=el('scan-btn');
  btn.disabled=true;
  btn.innerHTML='<div class="spin-sm"></div> Scanning…';
  el('scan-status').textContent='';

  const daysBack=parseInt(el('date-range').value);
  const ifThreshold=parseFloat(el('if-threshold').value);
  const minDate=getMinDate(daysBack);

  el('scan-progress').style.display='block';
  el('alerts-summary').style.display='none';
  el('alerts-list').innerHTML='';
  el('prog-fill').style.width='0%';

  // Flatten all products
  const allProducts=[];
  GROUPS.forEach(g=>g.products.forEach(p=>allProducts.push({...p,cat:g.cat,color:g.color})));
  const total=allProducts.length;

  const allResults=[];
  const seenPMIDs=new Set();

  for(let i=0;i<allProducts.length;i++){
    const prod=allProducts[i];
    el('prog-txt').textContent=`Scanning ${i+1}/${total}: ${prod.name}…`;
    el('prog-fill').style.width=Math.round(((i+1)/total)*100)+'%';

    try{
      const q=buildQuery(prod.name,prod.species);
      const ids=await pmSearch(q,minDate);
      if(ids.length){
        const papers=await pmSummary(ids);
        papers.forEach(paper=>{
          if(seenPMIDs.has(paper.pmid))return;
          seenPMIDs.add(paper.pmid);
          const IF=lookupIF(paper.journal);
          if(IF===null||IF>=ifThreshold){
            allResults.push({...paper,IF,product:prod.name,cat:prod.cat,color:prod.color});
          }
        });
      }
      // Small delay to be nice to NCBI
      await new Promise(r=>setTimeout(r,350));
    }catch(e){
      console.warn('Scan error for',prod.name,e);
    }
  }

  // Sort by IF descending (null IF at bottom)
  allResults.sort((a,b)=>{
    if(a.IF===null&&b.IF===null)return 0;
    if(a.IF===null)return 1;
    if(b.IF===null)return -1;
    return b.IF-a.IF;
  });

  el('scan-progress').style.display='none';
  renderAlerts(allResults,ifThreshold,daysBack);

  // Mark button if new high-impact found
  const hasHigh=allResults.some(r=>r.IF&&r.IF>=10);
  el('alert-btn').classList.toggle('has-new',hasHigh);

  btn.disabled=false;
  btn.innerHTML='<span id="scan-btn-icon">⟳</span> Scan All Products';
  el('scan-status').textContent=`Last scan: ${new Date().toLocaleTimeString()}`;
  scanning=false;
}

function renderAlerts(results,ifThreshold,daysBack){
  const list=el('alerts-list');list.innerHTML='';

  // Summary stats
  const withPapers=new Set(results.map(r=>r.product)).size;
  const highImpact=results.filter(r=>r.IF&&r.IF>=10).length;
  el('sum-found').textContent=results.length;
  el('sum-products').textContent=withPapers;
  el('sum-top').textContent=highImpact;
  el('sum-time').textContent=new Date().toLocaleString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});
  el('alerts-summary').style.display='flex';

  if(!results.length){
    list.innerHTML=`<div class="alerts-empty">No papers found matching IF ≥ ${ifThreshold} in the last ${daysBack} days.<br>Try widening the date range or lowering the impact factor threshold.</div>`;
    return;
  }

  const maxIF=Math.max(...results.map(r=>r.IF||0),1);

  results.forEach(r=>{
    const IF=r.IF;
    let cls='alert-card',badge='if-low-bg',barColor='#2e4060';
    if(IF&&IF>=20){cls+=' if-top';badge='if-top-bg';barColor='#a78bfa';}
    else if(IF&&IF>=10){cls+=' if-high';badge='if-high-bg';barColor='#10b981';}
    else if(IF&&IF>=5){cls+=' if-mid';badge='if-mid-bg';barColor='#f59e0b';}

    const link=r.doi?`https://doi.org/${r.doi}`:`https://pubmed.ncbi.nlm.nih.gov/${r.pmid}/`;
    const dateStr=[r.month,r.year].filter(Boolean).join(' ');
    const ifW=IF?Math.round((IF/maxIF)*100):0;
    const cleanTitle=r.title.replace(/<[^>]*>/g,'');

    const card=document.createElement('div');card.className=cls;
    card.innerHTML=`
      <span class="alert-if-badge ${badge}">${IF?'IF '+IF.toFixed(1):'IF unknown'}</span>
      <div class="alert-product-tag" style="border-color:${r.color}20;color:${r.color}aa">${r.product} · ${r.cat}</div>
      <div class="alert-title"><a href="${link}" target="_blank" rel="noopener">${cleanTitle||'View on PubMed'}</a></div>
      <div class="alert-meta">
        <span class="alert-journal">${r.journal||'Unknown Journal'}</span>
        ${dateStr?`<span class="alert-date">${dateStr}</span>`:''}
        <span class="alert-date">PMID ${r.pmid}</span>
      </div>
      ${r.authors?`<div class="alert-authors">${r.authors}</div>`:''}
      <div class="if-bar-row">
        <span class="if-bar-lbl">IMPACT FACTOR</span>
        <div class="if-bar-bg"><div class="if-bar-fill" style="width:${ifW}%;background:${barColor}"></div></div>
        <span class="if-val" style="color:${barColor}">${IF?IF.toFixed(1):'—'}</span>
      </div>`;
    list.appendChild(card);
  });
}
</script>
