@keyframes spin{to{transform:rotate(360deg)}}
.spin-sm{width:13px;height:13px;border:2px solid #3a1a6a;border-top-color:#a78bfa;border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
</style>
