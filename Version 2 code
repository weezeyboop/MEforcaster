.pubmed-btn{display:inline-flex;align-items:center;gap:6px;padding:8px 14px;background:#0f1e35;border:1px solid #1e4070;border-radius:6px;color:#5a9fdf;font-size:11px;font-weight:600;font-family:'Syne',sans-serif;text-decoration:none;margin-top:4px;cursor:pointer}
