.alert-title a:hover{text-decoration:underline}
.alert-meta{display:flex;flex-wrap:wrap;gap:6px;align-items:center;margin-bottom:4px}
.alert-journal{font-size:10px;font-weight:600;font-family:'Syne',sans-serif;color:#5a8ab0}
.alert-date{font-size:9px;font-family:'IBM Plex Mono',monospace;color:#3a5070;background:#131c2e;padding:1px 6px;border-radius:10px}
