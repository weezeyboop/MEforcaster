// ─── UI HELPERS ───────────────────────────────────────────────────────────────
let activeGroup=GROUPS[0], activeProd=null;
function el(id){return document.getElementById(id);}
function show(id){el(id).style.display='block';}
function hide(id){el(id).style.display='none';}
function setColor(c){document.documentElement.style.setProperty('--cc',c);}
function usp(arr){const s=new Set(),o=[];arr.forEach(x=>{if(!s.has(x)){s.add(x);o.push(x);}});return o;}
function spTag(s,big){
  const d=SP[s];if(!d)return'';
  return big
    ?`<span class="res-sp" style="background:${d.bg};color:${d.fg};border:1px solid ${d.br}">${d.label}</span>`
    :`<span class="sp ${d.cls}">${d.label}</span>`;
}
function fmt(n){return n>=1000?(n/1000).toFixed(1)+'k':String(n);}

function switchView(v){
  document.querySelectorAll('.view-tab').forEach(t=>t.classList.remove('active'));
  el('tab-'+v).classList.add('active');
  el('view-trend').style.display=v==='trend'?'block':'none';
  el('view-pubs').style.display=v==='pubs'?'block':'none';
}

// Build tabs
GROUPS.forEach((g,i)=>{
  const b=document.createElement('button');
  b.className='cat-tab'+(i===0?' active':'');
  b.textContent=g.cat;
  b.onclick=()=>{
    activeGroup=g;activeProd=null;
    document.querySelectorAll('.cat-tab').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');setColor(g.color);buildProducts();
    show('empty-state');hide('result');
  };
  el('cat-tabs').appendChild(b);
});

function buildProducts(){
  const row=el('product-row');row.innerHTML='';
  activeGroup.products.forEach(p=>{
    const b=document.createElement('button');b.className='p-tile';
    b.innerHTML=p.name+usp(p.species).map(s=>spTag(s,false)).join('');
    b.onclick=()=>selectProduct(p,b);row.appendChild(b);
  });
}

function selectProduct(p,btn){
  document.querySelectorAll('.p-tile').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  activeProd=p;
  const d=DATA[p.name];
  if(!d){show('empty-state');hide('result');return;}
  hide('empty-state');
  renderResult(p,d);
  show('result');
  switchView('trend');
}

function renderResult(p,d){
  setColor(activeGroup.color);
  el('res-cat').textContent=activeGroup.cat.toUpperCase()+' · PUBMED TREND ANALYSIS';
  el('res-name').textContent=p.name;
  el('res-species').innerHTML=usp(p.species).map(s=>spTag(s,true)).join('');
  el('res-meta').textContent='PubMed publication data · Updated Apr 2025';

  const c=d.c;
  const last=c[c.length-1],first=c[0];
  const growth=first>0?Math.round(((last-first)/first)*100):0;
  const prev=c[c.length-2],yoy=prev>0?Math.round(((last-prev)/prev)*100):0;
  const peak=c.reduce((mi,v,i)=>v>c[mi]?i:mi,0);
  const YEARS=[2020,2021,2022,2023,2024];

  el('s-papers').textContent=last.toLocaleString();
  const gEl=el('s-growth');gEl.textContent=(growth>0?'+':'')+growth+'%';
  gEl.style.color=growth>15?'#4ade80':growth<0?'#f87171':'#fbbf24';
  const yEl=el('s-yoy');yEl.textContent=(yoy>0?'+':'')+yoy+'%';
  yEl.style.color=yoy>0?'#4ade80':yoy<0?'#f87171':'#fbbf24';
  el('s-peak').textContent=YEARS[peak];
  el('s-peak').style.color=activeGroup.color;

  const chartEl=el('bar-chart');chartEl.innerHTML='';
  const maxC=Math.max(...c);
  c.forEach((v,i)=>{
    const pct=Math.max(4,Math.round((v/maxC)*100));
    const col=document.createElement('div');col.className='bar-col';
    col.innerHTML=`<div class="bar-n">${fmt(v)}</div><div class="bar-b" style="height:${pct}%;background:${activeGroup.color};opacity:${i===peak?1:.5}"></div><div class="bar-y">${YEARS[i]}</div>`;
    chartEl.appendChild(col);
  });

  const TL={Rising:{bg:'#10b98118',c:'#10b981',b:'#10b98150'},Stable:{bg:'#f59e0b18',c:'#f59e0b',b:'#f59e0b50'},Declining:{bg:'#ef444418',c:'#ef4444',b:'#ef444450'},Emerging:{bg:'#a78bfa18',c:'#a78bfa',b:'#a78bfa50'}};
  const DL={High:'#4ade80',Moderate:'#fbbf24',Low:'#64748b'};
  const tl=TL[d.t]||TL.Stable;
  el('fc-pill').innerHTML=`<span class="trend-pill" style="background:${tl.bg};color:${tl.c};border:1px solid ${tl.b}">${d.t}</span>`;
  el('fc-demand').innerHTML=`<span style="color:${DL[d.d]||'#64748b'}">${d.d} demand forecast · 2025</span>`;
  el('fc-conf').textContent=d.cf+'%';
  el('fc-rec').textContent=d.r;
  el('fc-drivers').innerHTML=d.dr.map(x=>`<div class="driver"><span class="d-arr">→</span><span>${x}</span></div>`).join('');
  el('fc-areas').innerHTML=d.a.map(x=>`<span class="area-tag">${x}</span>`).join('');

  // Publications
  const pubs=d.p||[];
  el('pub-count').textContent=pubs.length?`(${pubs.length})`:'';
  renderPubs(pubs,p,usp(p.species));
}

function renderPubs(pubs,prod,spArr){
  const list=el('pubs-list');list.innerHTML='';
  const searchURL=`https://pubmed.ncbi.nlm.nih.gov/?term=${encodeURIComponent('"'+prod.name+'" ('+spArr.map(s=>(SP[s]||{label:s}).label).join(' OR ')+') 2024:2025[pdat]')}&sort=pubdate`;

  // Always show PubMed search button at top
  const btnBox=document.createElement('div');
  btnBox.style.marginBottom='12px';
  btnBox.innerHTML=`<a class="pubmed-btn" href="${searchURL}" target="_blank" rel="noopener">🔬 Search latest papers on PubMed →</a>`;
  list.appendChild(btnBox);

  if(!pubs.length){
    const note=document.createElement('div');
    note.className='no-pubs-box';
    note.innerHTML=`No pre-indexed publications for this product.<br>Click the button above to search PubMed directly for the latest 2024–2025 papers.`;
    list.appendChild(note);
    return;
  }

  const sorted=[...pubs].sort((a,b)=>(b.if||0)-(a.if||0));
  const maxIF=Math.max(...sorted.map(p=>p.if||0),1);

  sorted.forEach(pub=>{
    const IF=pub.if;
    let cls='pub-card',badge='if-low-bg',barColor='#2e4060';
    if(IF>=20){cls+=' if-top';badge='if-top-bg';barColor='#a78bfa';}
    else if(IF>=10){cls+=' if-high';badge='if-high-bg';barColor='#10b981';}
    else if(IF>=5){cls+=' if-mid';badge='if-mid-bg';barColor='#f59e0b';}

    const link=pub.doi?`https://doi.org/${pub.doi}`:pub.pm?`https://pubmed.ncbi.nlm.nih.gov/${pub.pm}/`:'';
    const dateStr=[pub.m,pub.y].filter(Boolean).join(' ');
    const ifW=IF?Math.round((IF/maxIF)*100):0;

    const card=document.createElement('div');card.className=cls;
    card.innerHTML=`<span class="if-badge ${badge}">${IF?'IF '+IF.toFixed(1):'IF unknown'}</span>
<div class="pub-title">${link?`<a href="${link}" target="_blank" rel="noopener">${pub.ti}</a>`:pub.ti}${pub.n?'<span class="new-badge">NEW 2025</span>':''}</div>
<div class="pub-meta"><span class="pub-journal">${pub.j||''}</span>${dateStr?`<span class="pub-date">${dateStr}</span>`:''}</div>
${pub.au?`<div class="pub-authors">${pub.au}</div>`:''}
<div class="if-bar-row"><span class="if-bar-lbl">IMPACT FACTOR</span><div class="if-bar-bg"><div class="if-bar-fill" style="width:${ifW}%;background:${barColor}"></div></div><span class="if-val" style="color:${barColor}">${IF?IF.toFixed(1):'—'}</span></div>`;
    list.appendChild(card);
  });
}

